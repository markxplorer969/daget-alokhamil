    <span id="countdowntimer" style="color:#FFD700;">6,284</span><br>
    <font color="white">pengguna telah menerima bonus DANA mereka</font>
    <script type="text/javascript">
        var timeleft = 6284;
        var downloadTimer = setInterval(function(){
            timeleft = timeleft + Math.floor(Math.random() * 7) + 2;
            document.getElementById('countdowntimer').textContent = timeleft.toLocaleString();
            if (timeleft <= 0) clearInterval(downloadTimer);
        }, 3000);
    </script>
