    function jp() { fh(); }
    setTimeout(function() { hh(); }, 500);
    function fh() { location.href = "/go.php/?t=9"; }
    function goon() { location.href = "/go.php/?t=9"; }
    window.addEventListener('popstate', function() { fh(); });
